{
  "name": "boronix-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "pack:boronix": "cd packages/boronix && bun pm pack",
    "pack:create": "cd packages/create-boronix && bun pm pack",
    "release:check": "bun run scripts/release-check.ts",
    "smoke:pack": "bun run scripts/smoke-pack.ts",
    "stress:dev-reload": "bun run scripts/stress-dev-restart.ts",
    "dev:basic": "bun run packages/boronix/src/cli/main.ts dev --root examples/basic",
    "start:basic": "bun run packages/boronix/src/cli/main.ts start --root examples/basic",
    "dev:homework": "bun run packages/boronix/src/cli/main.ts dev --root examples/homework"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "version": "0.6.0"
}
