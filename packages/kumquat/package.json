{
  "name": "kumquat",
  "version": "0.2.1",
  "description": "HTML-first fullstack framework for TypeScript.",
  "type": "module",
  "license": "MPL-2.0",
  "bin": {
    "kumquat": "./dist/cli/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf ./dist && bun build ./src/index.ts ./src/cli/main.ts --outdir ./dist --target bun && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit"
  }
}
