{
  "name": "boronix",
  "version": "0.2.7",
  "description": "HTML-first fullstack framework for TypeScript.",
  "type": "module",
  "license": "MPL-2.0",
  "bin": {
    "boronix": "dist/cli/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "boronix",
    "typescript",
    "framework",
    "fullstack",
    "html",
    "ssr",
    "web-framework"
  ],
  "homepage": "https://github.com/dismonjames/boronix.ts#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/dismonjames/boronix.ts.git",
    "directory": "packages/boronix"
  },
  "bugs": {
    "url": "https://github.com/dismonjames/boronix.ts/issues"
  },
  "scripts": {
    "build": "rm -rf ./dist && bun build ./src/index.ts ./src/cli/main.ts --outdir ./dist --target bun && tsc -p tsconfig.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit"
  }
}